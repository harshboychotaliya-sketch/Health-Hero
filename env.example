# MedBuddy — Environment Variables
# Copy this file to .env for local development
# On Render: add each variable in Dashboard → Environment

# ── OpenRouter API (AI analysis)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Firebase Admin SDK (server-side token verification)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the ENTIRE downloaded JSON as a single line:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@YOUR_PROJECT_ID.iam.gserviceaccount.com","client_id":"CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Port (Render sets this automatically — leave as 3000 for local)
PORT=3000
